# Claude API key for generating posts
ANTHROPIC_API_KEY=your-anthropic-api-key

# Post Bridge API credentials
# Sign up at https://postbridge.app to get your API key
POSTBRIDGE_API_KEY=your-postbridge-api-key
POSTBRIDGE_WORKSPACE_ID=your-workspace-id

# Social media account IDs configured in Post Bridge
# Don't hunt for these in the dashboard: run `python main.py --accounts`
# and paste the lines it prints.
POSTBRIDGE_INSTAGRAM_ACCOUNT_ID=your-instagram-account-id
POSTBRIDGE_FACEBOOK_ACCOUNT_ID=your-facebook-account-id
POSTBRIDGE_TIKTOK_ACCOUNT_ID=your-tiktok-account-id
POSTBRIDGE_PINTEREST_ACCOUNT_ID=your-pinterest-account-id

# Pinterest board ID (required for Pinterest posts)
PINTEREST_BOARD_ID=your-pinterest-board-id

# Book configuration
BOOK_DIR=./books
BOOK_TITLE=Your Book Title
BOOK_AUTHOR=Your Name
BOOK_GENRE=Fiction

# Branding
BRAND_COLOR_PRIMARY=#1a1a2e
BRAND_COLOR_SECONDARY=#e94560
BRAND_COLOR_ACCENT=#0f3460
BRAND_FONT_COLOR=#ffffff

# Scheduling (24h format, comma-separated times, interpreted in POST_TIMEZONE)
POST_TIMES=09:00,13:00,18:00
POST_TIMEZONE=America/New_York
# Days between posts per platform (spreads content out)
DAYS_BETWEEN_POSTS=2

# Content generation
POSTS_PER_BATCH=7
CLAUDE_MODEL=claude-sonnet-4-6
