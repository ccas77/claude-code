# ── Stage 1: Foundations ────────────────────────────────────────────────
# Postgres (Neon via Vercel Marketplace populates this on deploy)
DATABASE_URL=postgres://user:pass@host/db

# Vercel Blob (create a Blob store in the Vercel dashboard).
# Leave blank locally: files fall back to .blob-local/ on disk.
BLOB_READ_WRITE_TOKEN=

# Global kill-switch. While true, NO paid AI calls are made — the pipeline
# runs with free placeholder generators (solid-color scenes, silent audio)
# so every stage can be exercised safely. Flip to false to go live.
DRY_RUN=true

# Vercel Cron sends this as a bearer token to /api/cron/worker.
# Generate any long random string. Unset = worker route is open (dev only).
CRON_SECRET=

# ── Stage 2: Sign-in ────────────────────────────────────────────────────
# Google OAuth (console.cloud.google.com → credentials → OAuth client).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Auth.js session encryption secret: `openssl rand -base64 32`
AUTH_SECRET=
# Comma-separated list of Google emails allowed to sign in. Fails closed.
ALLOWED_EMAILS=you@example.com

# Dev-only session bypass: when set AND NODE_ENV !== production, API routes
# act as this owner without OAuth. Never set in Vercel.
DEV_FAKE_OWNER_EMAIL=

# ── Stage 3: Script writing (LLM) ───────────────────────────────────────
# Uses the Vercel AI Gateway: authenticated automatically on Vercel (OIDC).
# For local dev with DRY_RUN=false, set an AI Gateway key:
AI_GATEWAY_API_KEY=
# Gateway model id for script generation.
SCRIPT_MODEL=google/gemini-2.5-flash

# ── Stage 4: Images (character refs + scenes) ───────────────────────────
# Gateway image model ("Nano Banana"). Reference images are attached to
# every scene call — that is what keeps characters consistent.
IMAGE_MODEL=google/gemini-2.5-flash-image-preview

# ── Stage 5: Narration (TTS) ────────────────────────────────────────────
OPENAI_API_KEY=
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy
