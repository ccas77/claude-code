# =============================================================================
# Bookshelf - environment variables
# Copy to .env.local for local dev, set in Vercel Project Settings for deploys.
# =============================================================================

# -----------------------------------------------------------------------------
# Stage 1 (Foundations) - REQUIRED to boot the app
# -----------------------------------------------------------------------------

# Postgres connection string. Recommend Neon via the Vercel Marketplace.
# Get one: `vercel integration add neon` or https://neon.tech
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Vercel Blob token. Get one from Vercel project > Storage > Create Blob store.
# Leave blank locally to use the local-disk fallback under .blob-local/.
BLOB_READ_WRITE_TOKEN=

# Single-user mode for now. The email of the sole owner - every row gets tagged.
# Multi-user is a flip later; the owner_id column already exists.
OWNER_EMAIL=cordeliacastel@gmail.com

# Global dry-run switch. When true, NO external side-effects:
# no posts, no paid API calls, no emails. Default ON for safety.
DRY_RUN=true

# Vercel Cron auth. Set in Vercel project settings; Vercel sends this as a
# Bearer token on cron-triggered routes so they can't be hit publicly.
CRON_SECRET=

# -----------------------------------------------------------------------------
# Stage 3 (Transcription) - needed before audio captions work
# -----------------------------------------------------------------------------

# Whisper provider: 'openai' (hosted) or 'replicate' (faster-whisper) or 'local'
WHISPER_PROVIDER=openai
OPENAI_API_KEY=
REPLICATE_API_TOKEN=

# -----------------------------------------------------------------------------
# Stage 4 (Genre recipes) - needed to distill style recipes from reference images
# -----------------------------------------------------------------------------

# Vision model for recipe distillation: 'gemini' or 'claude'
VISION_PROVIDER=gemini
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Stage 5 (Render) - image gen + image-to-video animation
# -----------------------------------------------------------------------------

# Primary image gen: 'higgsfield' or 'gemini'
IMAGE_PROVIDER_PRIMARY=higgsfield
IMAGE_PROVIDER_FALLBACK=gemini
HIGGSFIELD_API_KEY=

# Image-to-video animation
VIDEO_PROVIDER_PRIMARY=higgsfield
VIDEO_PROVIDER_FALLBACK=

# -----------------------------------------------------------------------------
# Stage 7 (post-bridge) - social posting
# -----------------------------------------------------------------------------

# Sign up at https://post-bridge.com, connect socials, generate API key.
POSTBRIDGE_API_KEY=

# -----------------------------------------------------------------------------
# Stage 8 (Notifications) - failure alerts
# -----------------------------------------------------------------------------

# How to notify on failure: 'email' or 'none' for now
NOTIFY_CHANNEL=email
RESEND_API_KEY=
NOTIFY_EMAIL_TO=cordeliacastel@gmail.com

# -----------------------------------------------------------------------------
# Scheduling
# -----------------------------------------------------------------------------

# Hours of buffer between Ready and post-time. Spec default: 3.
LEAD_TIME_HOURS=3
