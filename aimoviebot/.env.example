# Higgsfield: connected via OAuth (MCP-over-HTTP at https://mcp.higgsfield.ai/mcp).
# No API key needed. After deploy, visit /api/oauth/higgsfield once to connect.
# Tokens + dynamically-registered client are persisted in Vercel Blob.
#
# Optional overrides:
# HIGGSFIELD_MCP_URL=https://mcp.higgsfield.ai/mcp
# HIGGSFIELD_OAUTH_CLIENT_ID=
# HIGGSFIELD_OAUTH_CLIENT_SECRET=

# Vercel AI Gateway: NO env var needed in production on Vercel.
# OIDC auto-auth handles it. Only set this for local dev or non-Vercel hosts.
# AI_GATEWAY_API_KEY=

# Vercel Blob: auto-injected when a Blob store is linked to the project.
# BLOB_READ_WRITE_TOKEN=

# Optional. Defaults to https://${VERCEL_PROJECT_PRODUCTION_URL}. Set this if
# you want OAuth redirects to land somewhere other than your project's prod
# domain (e.g. a custom domain).
# APP_BASE_URL=
