# Higgsfield REST API credentials.
# Auth header format (per https://docs.higgsfield.ai/docs/how-to/introduction):
#   Authorization: Key {HIGGSFIELD_API_KEY}:{HIGGSFIELD_API_SECRET}
# Grab both from the Higgsfield dashboard under Account / API keys.
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=

# Vercel AI Gateway: NO env var needed in production on Vercel.
# OIDC auto-auth handles it. Only set this for local dev or a non-Vercel host.
# AI_GATEWAY_API_KEY=

# Vercel Blob: auto-injected when you link a Blob store in the Vercel
# project (Project -> Storage -> Create -> Blob). No manual entry.
# BLOB_READ_WRITE_TOKEN=
