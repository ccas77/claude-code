# ---------------------------------------------------------------------------
# tropesite configuration. Copy to `.env` and fill in. `.env` is gitignored.
# ---------------------------------------------------------------------------

# Where the catalog lives. Point this at your real pinfactory SQLite database to
# replace the sample data. Default: ./data/catalog.db
# TROPESITE_DB=/absolute/path/to/pinfactory.db

# --- Site identity ---------------------------------------------------------
SITE_URL=https://your-domain.com
SITE_BRAND=Your Brand Name
SITE_TAGLINE=Reader-first book recommendations by trope and vibe.
# Public byline persona (NOT your pen names). See the About page flag.
SITE_PERSONA=The Editors
SITE_TWITTER=@yourhandle
CONTACT_EMAIL=hello@your-domain.com

# --- Amazon Associates -----------------------------------------------------
# Every Amazon link carries a tracking ID. Register your DOMAIN and Pinterest
# account in your Associates profile (see SETUP.md). No shorteners/cloaking.
AMAZON_ASSOC_TAG=yourtag-20
# Optional per-section tracking IDs (fall back to AMAZON_ASSOC_TAG if unset):
AMAZON_ASSOC_TAG_TROPE=yourtag-trope-20
AMAZON_ASSOC_TAG_BOOKSLIKE=yourtag-like-20
AMAZON_ASSOC_TAG_BOOK=yourtag-book-20
# OneLink geo-routing so non-US clicks still monetize (true/false):
AMAZON_ONELINK=true
AMAZON_ONELINK_TAGS=UK:yourtag-21,CA:yourtag-20,DE:yourtag-21
AMAZON_MARKETPLACE=www.amazon.com

# --- Content engine (Anthropic API) ----------------------------------------
# If unset, `generate` uses the deterministic composer (no fabrication either way).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Email capture ----------------------------------------------------------
# A generic POST endpoint OR a hosted-form URL fallback. Email content links to
# SITE PAGES ONLY — never Amazon (Associates policy; enforced by audit).
EMAIL_FORM_ENDPOINT=
EMAIL_FORM_URL=
EMAIL_LIST_NAME=the monthly romance list

# --- Build tuning -----------------------------------------------------------
MIN_BOOKS_PER_PAGE=6

# --- Deploy -----------------------------------------------------------------
DEPLOY_TARGET=cloudflare
CF_PAGES_PROJECT=tropesite
